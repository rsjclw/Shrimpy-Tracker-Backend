# PostgreSQL connection (use Supabase connection string from Project Settings -> Database)
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE

# Supabase project URL (Project Settings -> API -> Project URL)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# No JWT secret needed; backend fetches the public key from Supabase automatically
# Server-only key for admin endpoints such as listing registered Auth users.
# Project Settings -> API -> service_role key. Never expose this to the frontend.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# CORS (Next.js dev origin)
FRONTEND_ORIGIN=http://localhost:3000

# Comma-separated Supabase Auth emails with global admin access
ADMIN_EMAILS=rasyidfajar01@gmail.com
